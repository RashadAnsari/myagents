{
  "mcpServers": {
    "playwright": {
      "command": "bash",
      "args": [
        "-c",
        "EXT=\"\"; [ -n \"${PLAYWRIGHT_MCP_EXTENSION_TOKEN:-}\" ] && EXT=\"--extension\"; ~/.myagents/plugins/albino/scripts/run-with-bunx.sh @playwright/mcp@latest $EXT"
      ]
    },
    "linkedin": {
      "command": "bash",
      "args": [
        "-c",
        "UV_HTTP_TIMEOUT=300 ~/.myagents/plugins/albino/scripts/run-with-uv.sh tool run mcp-server-linkedin@latest"
      ]
    }
  }
}

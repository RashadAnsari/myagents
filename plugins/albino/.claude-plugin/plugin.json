{
  "name": "albino",
  "version": "0.2.0",
  "description": "Personal productivity plugin: brings Rashad's workflows to Claude Code.",
  "author": {
    "name": "Rashad Ansari",
    "url": "https://github.com/RashadAnsari"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

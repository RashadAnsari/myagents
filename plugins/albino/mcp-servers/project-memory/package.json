{
  "name": "@myagents/project-memory-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic MCP server for durable, searchable project memory.",
  "bin": {
    "myagents-project-memory": "./src/index.ts"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",

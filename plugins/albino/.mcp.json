{
  "mcpServers": {
    "playwright": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "project-memory": {
      "command": "bash",
      "args": [
        "-c",
        "PLUGIN=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$PLUGIN\" ] && PLUGIN=\"$(pwd)\"; exec \"$PLUGIN/scripts/run-with-uv.sh\" run --directory \"$PLUGIN/mcp-servers/project-memory\" myagents-project-memory"
      ]
    }
  }
}
